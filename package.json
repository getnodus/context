{
  "name": "@getnodus/context",
  "version": "0.0.12",
  "description": "Personal context layer for AI agents. Your memory, portable across every agent you use.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "nodus-context": "./dist/cli/index.js",
    "nodus-context-mcp": "./dist/mcp/server.js",
    "nodus-context-server": "./dist/server/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "PROTOCOL.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && node --import tsx --test test/*.test.ts",
    "start:mcp": "node dist/mcp/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "bonjour-service": "^1.4.0",
    "gray-matter": "^4.0.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
